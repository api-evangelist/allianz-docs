{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/allianz-docs/refs/heads/main/json-schema/api-connect-vehicle-schema.json",
  "title": "Vehicle",
  "description": "Vehicle information for car insurance estimates",
  "type": "object",
  "properties": {
    "make": {
      "type": "string",
      "description": "Vehicle manufacturer",
      "example": "Toyota"
    },
    "model": {
      "type": "string",
      "description": "Vehicle model name",
      "example": "Camry"
    },
    "year": {
      "type": "integer",
      "description": "Year of manufacture",
      "example": 2022
    },
    "registration": {
      "type": "string",
      "description": "Vehicle registration number",
      "example": "ABC123"
    }
  }
}