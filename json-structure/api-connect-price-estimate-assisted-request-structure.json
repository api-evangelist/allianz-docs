{
  "type": "object",
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/allianz-docs/refs/heads/main/json-structure/api-connect-price-estimate-assisted-request-structure.json",
  "description": "Request body for creating a staff-assisted price estimate",
  "properties": {
    "customer_id": {
      "type": "string",
      "description": "Unique identifier for the customer",
      "example": "500123"
    },
    "product_type": {
      "type": "string",
      "description": "Type of insurance product to estimate",
      "enum": [
        "home",
        "landlord",
        "car"
      ],
      "example": "home"
    },
    "property_address": {
      "$ref": "#/components/schemas/Address"
    }
  },
  "required": [
    "customer_id",
    "product_type"
  ],
  "name": "PriceEstimateAssistedRequest"
}